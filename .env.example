# Backend Server Environment Variables
# Rename to .env and fill in your values

NODE_ENV=production
PORT=3000

# Firebase Service Account (JSON string)
FIREBASE_PROJECT_ID=jobfinder-b817d
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'

# Gemini API Key
GEMINI_API_KEY=your-gemini-api-key

# Cloudinary
CLOUDINARY_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Supabase
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-key

# Frontend URLs (for CORS)
FRONTEND_URL=http://localhost:5173,https://joblet-eight.vercel.app

# Optional: Sentry error tracking
SENTRY_DSN=your-sentry-dsn

# Firebase Storage Bucket
FIREBASE_STORAGE_BUCKET=jobfinder-b817d.firebasestorage.app

# Render deployment info
RENDER_EXTERNAL_URL=https://jobletserver.onrender.com
